{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FinDistillBI;Trusted_Connection=True;TrustServerCertificate=True;",
    "ClickHouse": null
  },
  "Database": {
    "Provider": "SqlServer"
  },
  "Features": {
    "UseRedis": false,
    "UseClickHouse": false
  },
  "DataSources": {
    "YahooFinance": {
      "Enabled": true,
      "Tickers": [ "AAPL", "MSFT", "SPY", "QQQ" ],
      "RequestDelayMs": 1000
    },
    "CoinGecko": {
      "Enabled": true,
      "CoinIds": [ "bitcoin", "ethereum" ],
      "VsCurrency": "usd",
      "ApiKey": null,
      "RequestDelayMs": 1500
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
