@model CryptoMarketViewModel
@{
    ViewData["Title"] = "Crypto Market Overview";

    string PctClass(decimal v) => v >= 0 ? "text-success" : "text-danger";
    string PctSign(decimal v) => v >= 0 ? "+" : "";

    // Dominance chart: top 5 + "Other"
    var top5 = Model.Coins.Take(5).ToList();
    var otherCap = Model.TotalMarketCap - top5.Sum(c => c.MarketCap);
    var dominanceLabels = top5.Select(c => c.Symbol).Append("Other").ToList();
    var dominanceData = top5
        .Select(c => Model.TotalMarketCap > 0 ? Math.Round(c.MarketCap / Model.TotalMarketCap * 100, 1) : 0m)
        .Append(Model.TotalMarketCap > 0 ? Math.Round(otherCap / Model.TotalMarketCap * 100, 1) : 0m)
        .ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Crypto Market Overview</h2>
        <small class="text-muted">Live data via CoinGecko · Top @Model.Limit coins by market cap</small>
    </div>
    <div class="d-flex gap-2">
        @foreach (var n in new[] { 10, 20, 50 })
        {
            <a asp-action="CryptoMarket" asp-route-limit="@n"
               class="btn btn-sm @(Model.Limit == n ? "btn-warning" : "btn-outline-secondary")">Top @n</a>
        }
    </div>
</div>

@if (!Model.Coins.Any())
{
    <div class="alert alert-warning">No live data available. Check that the CoinGecko API key is configured and try again.</div>
}
else
{
    <div class="row mb-4 g-3">
        <!-- Dominance donut -->
        <div class="col-lg-3 col-md-4">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-4">
                    <canvas id="dominanceChart" width="220" height="220"></canvas>
                    <p class="text-muted small mt-3 mb-0 text-center">Market Cap Dominance (Top 5)</p>
                </div>
            </div>
        </div>
        <!-- Top-3 highlight cards -->
        <div class="col-lg-9 col-md-8">
            <div class="row g-3 h-100">
                @foreach (var coin in Model.Coins.Take(3))
                {
                    <div class="col-md-4">
                        <div class="card bg-dark border-secondary h-100">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <img src="@coin.Image" width="28" height="28" class="rounded-circle" alt="@coin.Symbol" onerror="this.style.display='none'" />
                                    <span class="fw-bold fs-6">@coin.Symbol</span>
                                    <span class="badge bg-secondary">#@coin.MarketCapRank</span>
                                </div>
                                <div class="fs-4 fw-semibold font-monospace">
                                    $@coin.CurrentPrice.ToString("N2")
                                </div>
                                <div class="@PctClass(coin.PriceChangePercent24H) small mt-1">
                                    @PctSign(coin.PriceChangePercent24H)@coin.PriceChangePercent24H.ToString("F2")% (24h)
                                </div>
                                <hr class="my-2 border-secondary" />
                                <div class="d-flex justify-content-between small text-muted">
                                    <span>Market Cap</span>
                                    <span class="font-monospace">$@((coin.MarketCap / 1_000_000_000m).ToString("F1"))B</span>
                                </div>
                                <div class="d-flex justify-content-between small text-muted mt-1">
                                    <span>ATH</span>
                                    <span class="font-monospace @PctClass(coin.AthChangePercent)">$@coin.Ath.ToString("N2") (@coin.AthChangePercent.ToString("F1")%)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Full table -->
    <div class="table-responsive">
        <table class="table table-dark table-hover table-sm align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>#</th>
                    <th>Coin</th>
                    <th class="text-end">Price (USD)</th>
                    <th class="text-end">24h Change</th>
                    <th class="text-end">Market Cap</th>
                    <th class="text-end">Volume 24h</th>
                    <th class="text-end">Vol/MCap</th>
                    <th class="text-end">ATH</th>
                    <th class="text-end">From ATH</th>
                    <th class="text-end">Circ. Supply</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coin in Model.Coins)
                {
                    var volMcapRatio = coin.MarketCap > 0
                        ? (coin.TotalVolume / coin.MarketCap * 100m)
                        : 0m;

                    <tr>
                        <td class="text-muted small">@coin.MarketCapRank</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@coin.Image" width="20" height="20" class="rounded-circle" alt="" onerror="this.style.display='none'" />
                                <span class="fw-semibold">@coin.Symbol</span>
                                <span class="text-muted small d-none d-md-inline">@coin.Name</span>
                            </div>
                        </td>
                        <td class="text-end font-monospace">$@coin.CurrentPrice.ToString("N4")</td>
                        <td class="text-end @PctClass(coin.PriceChangePercent24H)">
                            @PctSign(coin.PriceChangePercent24H)@coin.PriceChangePercent24H.ToString("F2")%
                        </td>
                        <td class="text-end font-monospace">$@((coin.MarketCap / 1_000_000_000m).ToString("F2"))B</td>
                        <td class="text-end font-monospace">$@((coin.TotalVolume / 1_000_000m).ToString("F0"))M</td>
                        <td class="text-end small @(volMcapRatio > 20 ? "text-success" : "text-muted")">
                            @volMcapRatio.ToString("F1")%
                        </td>
                        <td class="text-end font-monospace">$@coin.Ath.ToString("N2")</td>
                        <td class="text-end @PctClass(coin.AthChangePercent)">
                            @PctSign(coin.AthChangePercent)@coin.AthChangePercent.ToString("F1")%
                        </td>
                        <td class="text-end font-monospace small">
                            @((coin.CirculatingSupply / 1_000_000m).ToString("F2"))M
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
        const dominanceCtx = document.getElementById('dominanceChart');
        if (dominanceCtx) {
            new Chart(dominanceCtx, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dominanceLabels)),
                    datasets: [{
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dominanceData)),
                        backgroundColor: ['#f7931a', '#627eea', '#26a17b', '#e84142', '#2775ca', '#6c757d'],
                        borderColor: '#212529',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: false,
                    cutout: '65%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#adb5bd', font: { size: 11 }, padding: 8 }
                        },
                        tooltip: {
                            callbacks: {
                                label: ctx => ` ${ctx.label}: ${ctx.parsed.toFixed(1)}%`
                            }
                        }
                    }
                }
            });
        }
    </script>
}
