@model RiskMetricsViewModel
@{
    ViewData["Title"] = "Risk Analytics";

    string SharpeClass(decimal v) => v >= 1m ? "text-success" : v >= 0m ? "text-warning" : "text-danger";
    string DrawdownClass(decimal v) => v >= -10m ? "text-success" : v >= -25m ? "text-warning" : "text-danger";
    string VolClass(decimal v) => v <= 20m ? "text-success" : v <= 40m ? "text-warning" : "text-danger";

    // Bar chart data (Sharpe Ratios)
    var sortedMetrics = Model.Metrics.OrderByDescending(m => m.SharpeRatio).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Risk Analytics</h2>
        <small class="text-muted">Sharpe Ratio &amp; Maximum Drawdown · @Model.Days-day window</small>
    </div>
    <div class="d-flex gap-2">
        @foreach (var d in new[] { 90, 180, 365 })
        {
            <a asp-action="Risk" asp-route-days="@d"
               class="btn btn-sm @(Model.Days == d ? "btn-warning" : "btn-outline-secondary")">@d D</a>
        }
    </div>
</div>

<!-- Methodology note -->
<div class="alert alert-secondary py-2 small mb-3">
    <strong>Methodology:</strong>
    Sharpe Ratio = (Ann. Return − 0%) / Ann. Volatility, annualised with √252.
    Max Drawdown = largest peak-to-trough decline over the window.
    Volatility = std dev of daily returns × √252.
    Risk-free rate assumed 0%.
</div>

@if (!Model.Metrics.Any())
{
    <div class="alert alert-warning">No data available. Run a <strong>Sync Now</strong> to load at least @Model.Days days of history.</div>
}
else
{
    <!-- Sharpe bar chart -->
    <div class="card bg-dark border-secondary mb-4">
        <div class="card-header border-secondary text-muted small">Sharpe Ratio by Asset (annualised, risk-free = 0%)</div>
        <div class="card-body">
            <canvas id="sharpeChart" height="80"></canvas>
        </div>
    </div>

    <!-- Metrics table -->
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ticker</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th class="text-end" title="Annualised Sharpe Ratio (risk-free = 0%)">Sharpe</th>
                    <th class="text-end" title="Maximum drawdown over the window">Max Drawdown</th>
                    <th class="text-end" title="Annualised volatility (std dev × √252)">Ann. Vol</th>
                    <th class="text-end" title="Mean daily return">Avg Daily Ret</th>
                    <th class="text-end">Days</th>
                    <th style="width:160px;" title="Risk/return visual">Risk vs Return</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in sortedMetrics)
                {
                    // Normalise drawdown bar: worst = -100%, cap display at 60%
                    var ddPct = Math.Min(Math.Abs(m.MaxDrawdown), 60m) / 60m * 100m;
                    var retPct = Math.Min(Math.Abs(m.MeanDailyReturn * 252), 100m);

                    <tr>
                        <td class="fw-semibold">
                            <a asp-controller="Asset" asp-action="Detail" asp-route-ticker="@m.Ticker"
                               class="text-decoration-none text-white">@m.Ticker</a>
                        </td>
                        <td class="text-muted small">@m.Name</td>
                        <td>
                            <span class="badge @(m.AssetType == "Crypto" ? "bg-warning text-dark" : m.AssetType == "ETF" ? "bg-info text-dark" : "bg-primary")">
                                @m.AssetType
                            </span>
                        </td>
                        <td class="text-end font-monospace @SharpeClass(m.SharpeRatio)">
                            @m.SharpeRatio.ToString("F2")
                        </td>
                        <td class="text-end font-monospace @DrawdownClass(m.MaxDrawdown)">
                            @m.MaxDrawdown.ToString("F1")%
                        </td>
                        <td class="text-end font-monospace @VolClass(m.AnnualisedVolatility)">
                            @m.AnnualisedVolatility.ToString("F1")%
                        </td>
                        <td class="text-end font-monospace @(m.MeanDailyReturn >= 0 ? "text-success" : "text-danger")">
                            @(m.MeanDailyReturn >= 0 ? "+" : "")@m.MeanDailyReturn.ToString("F3")%
                        </td>
                        <td class="text-end text-muted small">@m.TradingDays</td>
                        <td>
                            <!-- Risk-return mini-bar: green = return, red = drawdown -->
                            <div class="d-flex flex-column gap-1" style="font-size: 0.7rem;">
                                <div class="d-flex align-items-center gap-1">
                                    <span class="text-success" style="width:30px">Ret</span>
                                    <div class="progress flex-grow-1" style="height:6px;background:#2a2a3a;">
                                        <div class="progress-bar bg-success" style="width:@retPct.ToString("F0")%"></div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-1">
                                    <span class="text-danger" style="width:30px">DD</span>
                                    <div class="progress flex-grow-1" style="height:6px;background:#2a2a3a;">
                                        <div class="progress-bar bg-danger" style="width:@ddPct.ToString("F0")%"></div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Legend -->
    <div class="d-flex gap-4 mt-2 small text-muted">
        <span><span class="text-success">■</span> Sharpe ≥ 1.0 (good)</span>
        <span><span class="text-warning">■</span> 0.0–1.0 (moderate)</span>
        <span><span class="text-danger">■</span> &lt; 0.0 (poor)</span>
        <span class="ms-4"><span class="text-success">■</span> DD &gt; -10%</span>
        <span><span class="text-warning">■</span> -10% to -25%</span>
        <span><span class="text-danger">■</span> &lt; -25%</span>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
        const sharpeCtx = document.getElementById('sharpeChart');
        if (sharpeCtx) {
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sortedMetrics.Select(m => m.Ticker)));
            const sharpeData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sortedMetrics.Select(m => m.SharpeRatio)));
            const colors = sharpeData.map(v => v >= 1 ? 'rgba(25,135,84,0.8)' : v >= 0 ? 'rgba(255,193,7,0.8)' : 'rgba(220,53,69,0.8)');

            new Chart(sharpeCtx, {
                type: 'bar',
                data: {
                    labels,
                    datasets: [{
                        label: 'Sharpe Ratio',
                        data: sharpeData,
                        backgroundColor: colors,
                        borderColor: colors.map(c => c.replace('0.8', '1')),
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: ctx => ` Sharpe: ${ctx.parsed.y.toFixed(2)}`
                            }
                        }
                    },
                    scales: {
                        x: { ticks: { color: '#adb5bd' }, grid: { color: '#2a2a3a' } },
                        y: {
                            ticks: { color: '#adb5bd' },
                            grid: { color: '#2a2a3a' },
                            title: { display: true, text: 'Sharpe Ratio', color: '#adb5bd' }
                        }
                    }
                }
            });
        }
    </script>
}
